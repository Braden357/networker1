# Copy to .env.local and fill from Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: OpenAI for campaign parameter extraction (Phase 3). Never expose in NEXT_PUBLIC_*.
OPENAI_API_KEY=

# Server-only: Supabase service role for background campaign runs (Phase 4). Never in client or NEXT_PUBLIC_*.
# Dashboard → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=
